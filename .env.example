# Copy to .env for local use, or set these in the Vercel project's Environment Variables.
# Local dev (npm run crawl / serve) works with NONE of these set — it uses a local
# SQLite file and leaves the password gate open.

# --- Hosted storage (Turso / libSQL) ---
# From `turso db show <name>` and `turso db tokens create <name>`.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Password gate ---
# The site is OPEN when this is unset; set it in production to require sign-in.
# Change it anytime in the Vercel dashboard — no code change or redeploy of code.
SITE_PASSWORD=choose-a-strong-password

# --- Cron protection ---
# Protects /api/crawl. Vercel sends this as `Authorization: Bearer <CRON_SECRET>`
# to the scheduled job; also use it to trigger the crawl manually. Use a long random string.
CRON_SECRET=generate-a-long-random-string

# --- Optional crawl tuning ---
# THROTTLE_MS=400
# PER_PAGE=250
# PORT=4173
# RECENT_TICKS=25
